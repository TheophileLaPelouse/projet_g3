@article{almeida_systematic_2025,
	title = {A systematic review of explainability in computational intelligence for optimization},
	volume = {57},
	issn = {1574-0137},
	url = {https://www.sciencedirect.com/science/article/pii/S1574013725000401},
	doi = {10.1016/j.cosrev.2025.100764},
	abstract = {This systematic review explores the need for explainability in computational intelligence methods for optimization, such as metaheuristic optimizers, including evolutionary algorithms and swarm intelligence. The work focuses on four aspects: (1) the contribution of Explainable AI (XAI) methods to interpreting metaheuristic performance; (2) the influence of problem features on search behavior and explainability; (3) the role of mathematical theory in providing transparent explanations; and (4) the potential of metaheuristics to enhance the explainability of AI models, such as machine learning (ML). XAI methods such as SHAP, LIME, and visualization techniques provide valuable insights into metaheuristic performance, while landscape analysis and quality diversity approaches reveal algorithm performance across different problem landscapes. The review also explores how metaheuristic algorithms can enhance the interpretability of ML models, turning black-box models into more transparent systems. The work moves on to proposing ”Explainergy,” a novel concept for integrating explainability into metaheuristic algorithms within the energy domain, enhancing the transparency and usability of optimization models. This review is a foundation for future research combining explainability with evolutionary computation and metaheuristic optimization to address real-world challenges in diverse fields, including energy systems.},
	urldate = {2025-10-16},
	journal = {Computer Science Review},
	author = {Almeida, José and Soares, João and Lezama, Fernando and Limmer, Steffen and Rodemann, Tobias and Vale, Zita},
	month = aug,
	year = {2025},
	keywords = {Artificial intelligence, Black box optimization, Computational intelligence, Explainability, Explainergy, Metaheuristics, Systematic review},
	pages = {100764},
	file = {ScienceDirect Full Text PDF:/Users/theophilemounier/Zotero/storage/L4XYFX9H/Almeida et al. - 2025 - A systematic review of explainability in computational intelligence for optimization.pdf:application/pdf;ScienceDirect Snapshot:/Users/theophilemounier/Zotero/storage/QWTSG4SQ/S1574013725000401.html:text/html},
}

@inproceedings{article_1,
	title = {Community-{Based} {Energy} {Sharing} using {Game} {Theory} {Approaches} for {Benefit} {Distribution}},
	url = {https://ieeexplore.ieee.org/abstract/document/10744299},
	doi = {10.1109/ISAP63260.2024.10744299},
	abstract = {This paper is centered on the concept of community-based energy sharing, focusing on the integration of electric vehicles and battery management systems. The study employs mixed integer linear programming optimization techniques to minimize the total energy costs of the entire community by maximizing energy sharing within it. The investigation focuses on exploring methods of distribution of benefits among community members considering BESS and EV demand. The paper explores the midmarket rate, supply-demand rate, Shapley value, and Nucleolus analysis as methods to distribute the benefits generated by the energy community. The analysis contributes to understanding how community-based energy sharing can vary depending on the distribution method. Moreover, the study presents two scenarios with a community of up to 20 agents: PV generation without batteries and PV with batteries, both considering forecasted EV demand. The influence of transactions in the energy community allows for a cost-benefit of around 6 \% to 13 \%. When batteries are considered, the costs are reduced by up to 16 \%. The benefit distribution schemes are also investigated, and their excess is analyzed for each case.},
	urldate = {2025-10-17},
	booktitle = {2024 22nd {International} {Conference} on {Intelligent} {Systems} {Applications} to {Power} {Systems} ({ISAP})},
	author = {Almeida, José and Soares, João and Limmer, Steffen and Aliyan, Ehsan and Faia, Ricardo and Lezama, Fernando and Ramos, Sérgio and Vale, Zita},
	month = sep,
	year = {2024},
	keywords = {Batteries, Stability analysis, Optimization, Mixed integer linear programming, batteries, benefit distribution, Costs, electric vehicles, energy communities, game theory, Game theory, Intelligent systems, Power system stability, Predictive models, Regulation},
	pages = {1--6},
	file = {Snapshot:/Users/theophilemounier/Zotero/storage/XQKX8KWZ/10744299.html:text/html},
}

